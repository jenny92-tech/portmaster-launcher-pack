# Shared gptokeyb mapping for every LÖVE UI.
# Both face-button conventions confirm; X/Y/Start/Back cancel.
a = enter
b = enter
x = esc
y = esc
start = esc
back = esc
guide = enter

up = up
up = repeat
down = down
down = repeat
left = left
right = right

left_analog_up = up
left_analog_up = repeat
left_analog_down = down
left_analog_down = repeat
left_analog_left = left
left_analog_right = right

repeat_delay = 360
repeat_interval = 90
