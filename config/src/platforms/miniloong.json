{
  "display_name": "MiniLoong Pocket One",
  "priority": 1000,
  "support": {
    "device_class": "tested",
    "target_confirmation": "detected"
  },
  "recognition": {
    "kind": "file_exists",
    "path": "/loong/loong_version"
  },
  "required_adapters": [
    "predicate.v1",
    "path.v1",
    "frontend.v1",
    "library.v1",
    "python.v1",
    "lifecycle.v1"
  ],
  "paths": {
    "scripts": {
      "strategy": "launcher_dir"
    },
    "launcher_directory": {
      "strategy": "literal",
      "value": "/mnt/sdcard/roms"
    },
    "game_data": {
      "strategy": "literal",
      "value": "/mnt/sdcard/roms/ports"
    },
    "portmaster_core": {
      "strategy": "literal",
      "value": "/mnt/sdcard/roms/ports/PortMaster"
    },
    "frontend": {
      "strategy": "launcher_dir"
    },
    "images": {
      "strategy": "relative_to",
      "base": "scripts",
      "suffix": "images"
    }
  },
  "source_route": "miniloong-custom",
  "frontend": {
    "management": "app",
    "kind": "script-internal",
    "names": [
      "PortMaster.sh"
    ],
    "primary": "PortMaster.sh",
    "control_source": null,
    "core_launcher_source": null,
    "remove_core_launcher": false,
    "empty_tasksetter": false,
    "core_executable": "PortMaster.sh",
    "frontend_executable": "PortMaster.sh",
    "install_map": [
      {
        "source": "miniloong/PortMaster.txt",
        "target": "PortMaster.sh",
        "executable": true
      }
    ]
  },
  "libraries": {
    "resolution": "first_complete",
    "groups": {
      "sdl2": {
        "required_sonames": [
          "libSDL2-2.0.so.0",
          "libSDL2_image-2.0.so.0",
          "libSDL2_mixer-2.0.so.0",
          "libSDL2_ttf-2.0.so.0"
        ],
        "candidates": [
          "/usr/lib"
        ]
      },
      "gles": {
        "required_sonames": [
          "libGLESv2.so"
        ],
        "candidates": [
          "/usr/lib"
        ]
      }
    }
  },
  "python": {
    "mode": "runtime_mount",
    "prefer_system": true,
    "runtime": "python_3.11",
    "image": "{portmaster_core}/libs/python_3.11.squashfs",
    "mountpoint": "/tmp/portmaster-python"
  },
  "health": [
    {
      "kind": "required_file",
      "path": "{portmaster_core}/control.txt"
    },
    {
      "kind": "required_file",
      "path": "{portmaster_core}/device_info.txt"
    },
    {
      "kind": "required_file",
      "path": "{portmaster_core}/funcs.txt"
    },
    {
      "kind": "one_of_files",
      "paths": [
        "{portmaster_core}/pugwash",
        "{portmaster_core}/harbourmaster"
      ]
    },
    {
      "kind": "executable_file",
      "path": "{portmaster_core}/PortMaster.sh"
    },
    {
      "kind": "archive_or_nonempty_directory",
      "archive": "{portmaster_core}/pylibs.zip",
      "directory": "{portmaster_core}/pylibs"
    },
    {
      "kind": "python_imports_or_runtime",
      "imports": [
        "sys",
        "encodings",
        "zipfile",
        "hashlib"
      ],
      "runtime": "python_3.11"
    }
  ],
  "preserved_dirs": [
    "libs",
    "config",
    "themes",
    "logs",
    "cache"
  ],
  "managed_roots": [
    {
      "path": "portmaster_core",
      "owner": "app",
      "preserve": "preserved_dirs"
    },
    {
      "path": "frontend",
      "owner": "app",
      "names": [
        "PortMaster.sh"
      ]
    },
    {
      "path": "game_data",
      "owner": "port-user-data"
    },
    {
      "path": "images",
      "owner": "frontend-artwork"
    }
  ],
  "capabilities": {
    "manage_portmaster": true,
    "install_portmaster": true,
    "update_portmaster": true,
    "repair_runtimes": true,
    "manage_ports": true,
    "manage_frontend": true,
    "manage_images": true,
    "manage_artwork": true,
    "trash": true,
    "leftovers": true,
    "cleanup_appledouble": true
  },
  "environment_scopes": [
    "appmanager",
    "love_ui",
    "portmaster",
    "runtime_tool",
    "game_launcher"
  ],
  "lifecycle": {
    "display_backend": "wayland_then_kms",
    "input_helper": "gptokeyb",
    "wait_for_ui": true,
    "cleanup_input_helper": true
  },
  "display": {
    "default_width": 960,
    "default_height": 720,
    "rotation": "system"
  },
  "input": {
    "analog_sticks": 2,
    "controller_database": "bundled",
    "tty": "/dev/tty0"
  }
}
