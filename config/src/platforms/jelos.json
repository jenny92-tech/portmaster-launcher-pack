{
  "display_name": "JELOS",
  "priority": 690,
  "support": {
    "device_class": "official-untested",
    "target_confirmation": "detected"
  },
  "recognition": {
    "kind": "os_release_equals",
    "field": "OS_NAME",
    "value": "JELOS",
    "case_insensitive": true
  },
  "required_adapters": [
    "predicate.v1",
    "path.v1",
    "frontend.v1",
    "library.v1",
    "python.v1"
  ],
  "paths": {
    "scripts": {
      "strategy": "launcher_dir"
    },
    "launcher_directory": {
      "strategy": "parent",
      "of": "game_data"
    },
    "game_data": {
      "strategy": "first_existing",
      "candidates": [
        "/storage/roms/ports",
        "/roms/ports"
      ]
    },
    "portmaster_core": {
      "strategy": "relative_to",
      "base": "game_data",
      "suffix": "PortMaster"
    },
    "frontend": {
      "strategy": "platform_core"
    }
  },
  "source_route": "system",
  "frontend": {
    "management": "system",
    "kind": "core-internal",
    "names": [],
    "primary": "PortMaster.sh",
    "control_source": null,
    "core_launcher_source": null,
    "remove_core_launcher": false,
    "empty_tasksetter": false,
    "core_executable": "PortMaster.sh",
    "frontend_executable": null,
    "install_map": []
  },
  "libraries": {
    "groups": {
      "system_sdl2": {
        "required_sonames": [
          "libSDL2-2.0.so.0",
          "libSDL2_image-2.0.so.0",
          "libSDL2_mixer-2.0.so.0",
          "libSDL2_ttf-2.0.so.0"
        ],
        "candidates": [
          "/lib",
          "/lib64",
          "/usr/lib",
          "/usr/lib64",
          "/lib/aarch64-linux-gnu",
          "/usr/lib/aarch64-linux-gnu"
        ]
      }
    }
  },
  "python": {
    "mode": "system",
    "imports": [
      "sys",
      "encodings",
      "zipfile",
      "hashlib"
    ]
  },
  "health": [
    {
      "kind": "required_file",
      "path": "{portmaster_core}/control.txt"
    },
    {
      "kind": "one_of_files",
      "paths": [
        "{portmaster_core}/pugwash",
        "{portmaster_core}/harbourmaster"
      ]
    },
    {
      "kind": "executable_file",
      "path": "{portmaster_core}/PortMaster.sh"
    },
    {
      "kind": "archive_or_nonempty_directory",
      "archive": "{portmaster_core}/pylibs.zip",
      "directory": "{portmaster_core}/pylibs"
    }
  ],
  "preserved_dirs": [
    "libs",
    "config",
    "themes",
    "logs",
    "cache"
  ],
  "capabilities": {
    "manage_portmaster": false,
    "install_portmaster": false,
    "update_portmaster": false,
    "repair_runtimes": true,
    "manage_ports": true,
    "manage_frontend": false,
    "manage_images": false,
    "manage_artwork": false,
    "trash": true,
    "leftovers": true,
    "cleanup_appledouble": true,
    "scan_script_images": false
  },
  "environment_scopes": [
    "love_ui"
  ],
  "display": {
    "default_width": 1280,
    "default_height": 720
  },
  "input": {
    "analog_sticks": 2,
    "tty": "/dev/tty0"
  }
}
