{
  "display_name": "Generic PortMaster device",
  "priority": 0,
  "support": {
    "device_class": "unsupported-known",
    "target_confirmation": "existing_core_or_override"
  },
  "recognition": {
    "kind": "always"
  },
  "required_adapters": [
    "predicate.v1",
    "path.v1",
    "frontend.v1",
    "library.v1",
    "python.v1",
    "lifecycle.v1"
  ],
  "paths": {
    "scripts": {
      "strategy": "launcher_dir"
    },
    "launcher_directory": {
      "strategy": "parent",
      "of": "game_data"
    },
    "game_data": {
      "strategy": "parent",
      "of": "scripts"
    },
    "portmaster_core": {
      "strategy": "first_existing",
      "candidates": [
        "/opt/system/Tools/PortMaster",
        "/opt/tools/PortMaster",
        "/userdata/system/.local/share/PortMaster",
        "/mnt/SDCARD/Apps/PortMaster/PortMaster",
        "/mnt/mmc/MUOS/PortMaster",
        "/mnt/sdcard/Roms/.portmaster/PortMaster",
        "/mnt/sdcard/roms/ports/PortMaster",
        "/sdcard/roms/ports/PortMaster"
      ],
      "on_missing": "unresolved"
    },
    "frontend": {
      "strategy": "launcher_dir"
    }
  },
  "source_route": "official",
  "frontend": {
    "management": "app",
    "kind": "script-internal",
    "names": [
      "PortMaster.sh"
    ],
    "primary": "PortMaster.sh",
    "control_source": null,
    "core_launcher_source": null,
    "remove_core_launcher": false,
    "empty_tasksetter": false,
    "core_executable": "PortMaster.sh",
    "frontend_executable": "PortMaster.sh",
    "install_map": [
      {
        "source": "PortMaster.sh",
        "target": "PortMaster.sh",
        "executable": true
      }
    ]
  },
  "libraries": {
    "resolution": "first_complete",
    "groups": {
      "system_sdl2": {
        "required_sonames": [
          "libSDL2-2.0.so.0",
          "libSDL2_image-2.0.so.0",
          "libSDL2_mixer-2.0.so.0",
          "libSDL2_ttf-2.0.so.0"
        ],
        "candidates": [
          "/usr/lib",
          "/lib"
        ]
      },
      "gles": {
        "required_sonames": [
          "libGLESv2.so"
        ],
        "candidates": [
          "/usr/lib",
          "/lib"
        ]
      }
    }
  },
  "python": {
    "mode": "system",
    "imports": [
      "sys",
      "encodings",
      "zipfile",
      "hashlib"
    ]
  },
  "health": [
    {
      "kind": "required_file",
      "path": "{portmaster_core}/control.txt"
    },
    {
      "kind": "one_of_files",
      "paths": [
        "{portmaster_core}/pugwash",
        "{portmaster_core}/harbourmaster"
      ]
    },
    {
      "kind": "archive_or_nonempty_directory",
      "archive": "{portmaster_core}/pylibs.zip",
      "directory": "{portmaster_core}/pylibs"
    }
  ],
  "preserved_dirs": [
    "libs",
    "config",
    "themes",
    "logs",
    "cache"
  ],
  "managed_roots": [
    {
      "path": "portmaster_core",
      "owner": "app",
      "preserve": "preserved_dirs"
    },
    {
      "path": "frontend",
      "owner": "app",
      "names": [
        "PortMaster.sh"
      ]
    },
    {
      "path": "game_data",
      "owner": "port-user-data"
    }
  ],
  "capabilities": {
    "manage_portmaster": true,
    "install_portmaster": true,
    "update_portmaster": true,
    "repair_runtimes": true,
    "manage_ports": true,
    "manage_frontend": true,
    "manage_images": false,
    "manage_artwork": false,
    "trash": true,
    "leftovers": true,
    "cleanup_appledouble": true
  },
  "environment_scopes": [
    "appmanager",
    "love_ui",
    "portmaster",
    "runtime_tool",
    "game_launcher"
  ],
  "lifecycle": {
    "display_backend": "wayland_then_kms",
    "input_helper": "gptokeyb",
    "wait_for_ui": true,
    "cleanup_input_helper": true
  },
  "display": {
    "default_width": 960,
    "default_height": 720,
    "rotation": "system"
  },
  "input": {
    "analog_sticks": 2,
    "controller_database": "bundled",
    "tty": "/dev/tty0"
  }
}
