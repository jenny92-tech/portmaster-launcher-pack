#
# PORTMASTER: sts2_lite, Slay the Spire 2.sh
# Stage-1: shared love settings UI (run_love_launcher_ui, logic in
# _kit/portmaster_common.sh) writes launch_config.env; its display env stays
# confined to the subshell and never leaks into stage-2.
# Stage-2: patch the save, then run the game's godot.mono.
# Constraints still apply (see docs): the stage-2 game must not use
# gptokeyb/EVDEV grab, must not pass --verbose, and DEFSHADER must not contain
# rect. The love launcher's gptokeyb is transient and is killed when love exits.

#@KIT-BEGIN
KIT="$(cd "$(dirname "$0")/../../../_kit" && pwd)"
source "$KIT/portmaster_bootstrap.sh"
#@KIT-END
portmaster_discover "$(cd "$(dirname "$0")" && pwd)"
source $controlfolder/control.txt
[ -f "${controlfolder}/mod_${CFW_NAME}.txt" ] && source "${controlfolder}/mod_${CFW_NAME}.txt"
get_controls

PORT_NAME=sts2
LOG_PREFIX="[STS2-LOVE]"
for candidate in "/$directory/ports/sts2" "/mnt/sdcard/roms/ports/sts2" "/mnt/sdcard/mmcblk1p1/Data/ports/sts2" "/roms/ports/sts2"; do
  [ -d "$candidate" ] && GAMEDIR="$candidate" && break
done
CONFDIR="$GAMEDIR/conf"
mkdir -p "$CONFDIR"
cd "$GAMEDIR" || exit 1

#@KIT-BEGIN
KIT="$(cd "$(dirname "$0")/../../../_kit" && pwd)"
source "$KIT/portmaster_common.sh"
#@KIT-END

export LD_LIBRARY_PATH="/usr/lib:/usr/lib64:${LD_LIBRARY_PATH}"
# Display (for the stage-2 game): use wayland when a wayland socket exists
# (MiniLoong/weston); otherwise (bare KMS devices) use dummy and let SDL2's own
# KMS+GBM+EGL drive the panel directly.
# (love stage-1's display env is decided independently by run_love_launcher_ui
#  inside its own subshell — unaffected by this, and it does not leak out.)
if [ -S "/run/wayland-0" ] || [ -S "${XDG_RUNTIME_DIR:-/run}/wayland-0" ]; then
  export SDL_VIDEODRIVER=wayland
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run}"
  export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
else
  export SDL_VIDEODRIVER=dummy
  export SDL_AUDIODRIVER=alsa
fi
export GODOT_DISABLE_PARTICLES=1
export GODOT_DEFSHADER_TYPES="mesh,multimesh"

# Logs are discarded by default; drop a .debug file in GAMEDIR to write /tmp.
if [ -f "$GAMEDIR/.debug" ]; then RUNLOG=/tmp/sts2_run.log; else RUNLOG=/dev/null; fi

# stage 1: love settings UI (exit code 42 = start the game; anything else does
# pm_finish;exit internally)
run_love_launcher_ui

# stage 2: the game itself
SLL_ENV="$LAUNCH_ENV"
[ -f "$SLL_ENV" ] && source "$SLL_ENV"
case "${SLL_LANGUAGE:-}" in en_US|zh_CN) ;; *) SLL_LANGUAGE=zh_CN ;; esac
case "${SLL_QUALITY:-}" in smooth|balanced|quality) ;; *) SLL_QUALITY=balanced ;; esac
SLL_SWAP_AB="${SLL_SWAP_AB:-off}"
SLL_SWAP_XY="${SLL_SWAP_XY:-off}"
export SLL_LANGUAGE SLL_QUALITY
case "$SLL_LANGUAGE" in zh_CN) GAME_LANG=zhs ;; *) GAME_LANG=eng ;; esac
# The game offers only two aspect ratios (four_by_three / sixteen_by_nine).
# Only true widescreen (W/H >= 1.5) gets 16:9; everything else (4:3, 1:1,
# portrait) gets 4:3 — 4:3 crops the least on 1:1. W*2 >= H*3 means W/H >= 1.5.
if [ $((DISPLAY_WIDTH * 2)) -ge $((DISPLAY_HEIGHT * 3)) ]; then GAME_ASPECT=sixteen_by_nine; else GAME_ASPECT=four_by_three; fi

# A/B and X/Y swaps → input_remap.cfg (the game's godot.mono reads it from
# GAMEDIR). The godot launcher wrote this from the UI's _write_input_remap_cfg;
# the love launcher cannot write godot files, so stage-2 writes it here from the
# SLL_SWAP_AB/XY values love passed out. Required — without it button swap does
# nothing.
{
  echo "# Generated by launcher.sh from love launcher choices."
  echo "# swap_ab=${SLL_SWAP_AB:-off} swap_xy=${SLL_SWAP_XY:-off}"
  echo ""
  echo "[buttons]"
  if [ "$SLL_SWAP_AB" = "on" ]; then echo "a = BUTTON_B"; echo "b = BUTTON_A"; else echo "a = BUTTON_A"; echo "b = BUTTON_B"; fi
  if [ "$SLL_SWAP_XY" = "on" ]; then echo "x = BUTTON_Y"; echo "y = BUTTON_X"; else echo "x = BUTTON_X"; echo "y = BUTTON_Y"; fi
} > "$GAMEDIR/input_remap.cfg"

# Touch only the language and aspect_ratio keys in settings.save, nothing else
# (settings are separate from progress saves, which live in profile*/saves/ and
# are never touched here). Safeguard: the edit goes to a temp file and is only
# atomically mv'd back once validation passes (non-empty + at least half the
# original size + ends with } after whitespace is stripped); if any check fails
# the temp file is discarded and the original is left untouched. An in-place
# edit could truncate the save to 0 bytes — better to skip this run than to
# corrupt it. Pure sed: the device has no python3.
sts2_patch_save() {
  local SF="$1" tmp="$1.new.$$" osz nsz
  sed -e 's/"language": "[a-z]*"/"language": "'"$GAME_LANG"'"/' \
      -e 's/"aspect_ratio": "[a-z_]*"/"aspect_ratio": "'"$GAME_ASPECT"'"/' \
      "$SF" > "$tmp" 2>/dev/null || { rm -f "$tmp"; return; }
  osz=$(wc -c < "$SF" 2>/dev/null || echo 0)
  nsz=$(wc -c < "$tmp" 2>/dev/null || echo 0)
  if [ "${nsz:-0}" -gt 0 ] && [ "${nsz:-0}" -ge $(( ${osz:-0} / 2 )) ] && \
     tail -c 8 "$tmp" | tr -d '[:space:]' | grep -q '}$'; then
    mv -f "$tmp" "$SF" && echo "$LOG_PREFIX settings.save: language=$GAME_LANG aspect=$GAME_ASPECT (safe write)"
  else
    rm -f "$tmp" 2>/dev/null
    echo "$LOG_PREFIX settings.save validation failed — left untouched, not risking it"
  fi
}

# On first launch, when no settings.save exists yet, seed handheld factory
# defaults (verified on device: the game merges in missing keys and fills the
# rest of the defaults itself, so a partial file does not crash it). Two files:
#   settings.save — language/aspect (this run) + MSAA off (msaa=0) + volume 0.8.
#   prefs.save    — text effects off (text_effects_enabled=false; lives under
#                   profile1/saves/).
# Seeded only when there is no save at all; an existing save is never
# overwritten (player progress/settings are not touched). The factory defaults
# beyond language/aspect are seeded this once; later in-game changes persist.
_have_save=0
for SF in "$CONFDIR"/SlayTheSpire2/*/*/settings.save; do [ -f "$SF" ] && { _have_save=1; break; }; done
if [ "$_have_save" = "0" ]; then
  mkdir -p "$CONFDIR/SlayTheSpire2/default/1/profile1/saves"
  printf '{\n  "language": "%s",\n  "aspect_ratio": "%s",\n  "msaa": 0,\n  "volume_master": 0.8,\n  "volume_bgm": 0.8,\n  "volume_sfx": 0.8,\n  "volume_ambience": 0.8\n}\n' \
    "$GAME_LANG" "$GAME_ASPECT" > "$CONFDIR/SlayTheSpire2/default/1/settings.save" &&
    echo "$LOG_PREFIX first launch: seeded settings.save (language/aspect + MSAA off/volume 0.8)"
  printf '{\n  "text_effects_enabled": false\n}\n' \
    > "$CONFDIR/SlayTheSpire2/default/1/profile1/saves/prefs.save" &&
    echo "$LOG_PREFIX first launch: seeded prefs.save (text effects off)"
fi

for SF in "$CONFDIR"/SlayTheSpire2/*/*/settings.save; do
  [ -f "$SF" ] || continue
  sts2_patch_save "$SF"
done

# Incremental gamedata sync — the channel for players to update game files.
GAMEDATA="$GAMEDIR/gamedata"
if [ -d "$GAMEDATA/data_sts2_linuxbsd_arm64" ]; then
  cp -fu "$GAMEDATA/data_sts2_linuxbsd_arm64/"*.dll  "$GAMEDIR/data_sts2_linuxbsd_arm64/" 2>/dev/null
  cp -fu "$GAMEDATA/data_sts2_linuxbsd_arm64/"*.json "$GAMEDIR/data_sts2_linuxbsd_arm64/" 2>/dev/null
fi

cat > "$GAMEDIR/override.cfg" << 'EOG'
[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[dotnet]
project/assembly_name="sts2_compat"
EOG

audio_setup > /dev/null 2>&1
[ -f "$GAMEDIR/.debug" ] && install_exit_trap
pm_platform_helper "godot.mono"

( LANG="${SLL_LANGUAGE}.UTF-8" XDG_CONFIG_HOME="$CONFDIR" XDG_DATA_HOME="$CONFDIR" \
  exec -a unityloader ./godot.mono --display-driver sdl2 --rendering-driver opengl3 \
  --resolution ${DISPLAY_WIDTH}x${DISPLAY_HEIGHT} \
  --main-pack "$GAMEDIR/gamedata/pcks/SlayTheSpire2.pck" ) > "$RUNLOG" 2>&1

pm_finish
