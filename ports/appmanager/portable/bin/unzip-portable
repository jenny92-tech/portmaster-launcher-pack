#!/bin/sh
set -eu
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

# The managed installer uses Info-ZIP's `-Z1` mode to validate every archive
# path before extraction. BusyBox unzip has no `-Z`, so provide the same
# one-entry-per-line contract from its quiet listing output.
if [ "$#" -eq 2 ] && [ "$1" = "-Z1" ]; then
  "$SELF_DIR/busybox-portable" unzip -lq "$2" | awk '
    $1 ~ /^[0-9]+$/ && $2 ~ /^[0-9-]+$/ && $3 ~ /^[0-9:]+$/ && NF >= 4 {
      name = $4
      for (i = 5; i <= NF; i++) name = name " " $i
      print name
      found = 1
    }
    END { if (!found) exit 1 }
  '
  exit $?
fi

exec "$SELF_DIR/busybox-portable" unzip "$@"
