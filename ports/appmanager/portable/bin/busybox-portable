#!/bin/sh
set -eu

BIN_DIR=$0
case "$BIN_DIR" in */*) BIN_DIR=${BIN_DIR%/*} ;; *) BIN_DIR=. ;; esac
BIN_DIR=$(CDPATH= cd -- "$BIN_DIR" && pwd)
APP_ROOT=$(CDPATH= cd -- "$BIN_DIR/.." && pwd)
MUSL="$APP_ROOT/runtime/musl"

exec "$MUSL/libc.musl-aarch64.so.1" \
  --library-path "$MUSL" \
  "$BIN_DIR/busybox" "$@"
