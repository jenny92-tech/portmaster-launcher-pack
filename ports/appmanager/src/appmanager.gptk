# gptokeyb: joypad → keyboard。godot 3 默认 InputMap 已绑 ARROW → ui_up/down/
# left/right, ENTER → ui_accept, ESC → ui_cancel。
#
# 跟游戏启动器不同, 这里 B 必须是"返回"而不是第二个"确定" —— 这个 APP 会删东西,
# 用户在确认页要能退出去。
a = enter
b = esc
x = esc
y = esc
start = enter
back = esc
guide = esc

up = up
up = repeat
down = down
down = repeat
left = left
right = right

left_analog_up = up
left_analog_up = repeat
left_analog_down = down
left_analog_down = repeat
left_analog_left = left
left_analog_right = right

# 和 APP 内部的长按节奏保持一致。部分系统的键盘层会自己重复，
# TrimUI 则必须在 gptokeyb 中显式启用 repeat。
repeat_delay = 360
repeat_interval = 90
