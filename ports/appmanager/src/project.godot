; APP Manager — Godot 3.5 / frt aarch64 项目。
config_version=4

[application]

config/name="APP Manager"
run/main_scene="res://bootstrap.tscn"

[display]

; 640x480 只是最低布局基准，不是固定逻辑画布。必须按设备原生分辨率绘制：
; 2D stretch 会先生成 640 宽的字体贴图，再在 MiniLoong 960x720 上放大 1.5 倍，
; 字形落在非整数像素采样上会发糊。app_ui.gd 自己负责按分辨率调整密度。
window/size/width=640
window/size/height=480
window/stretch/mode="disabled"
window/handheld/orientation="landscape"

[rendering]

environment/default_clear_color=Color( 0.08, 0.08, 0.10, 1.0 )
quality/driver/driver_name="GLES2"
