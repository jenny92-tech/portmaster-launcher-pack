# Target gptokeyb a/b names are opposite to the printed face-button labels.
# Raw a cancels and raw b confirms => physical A confirms, physical B cancels.
a = esc
b = enter
x = esc
y = esc
start = enter
back = esc
guide = esc

up = up
up = repeat
down = down
down = repeat
left = left
right = right

left_analog_up = up
left_analog_up = repeat
left_analog_down = down
left_analog_down = repeat
left_analog_left = left
left_analog_right = right

repeat_delay = 360
repeat_interval = 90
